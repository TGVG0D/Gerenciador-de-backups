<FilesMatch "^\.env|dados\.json|categorias\.json|totp\.php|activity\.log|\.htaccess$">
    Require all denied
</FilesMatch>

# Ocultar erros 403 (Acesso negado) e transformá-los em 404 (Não encontrado)
ErrorDocument 403 /Backups/404
ErrorDocument 404 /Backups/404

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Esconder extensão .php nas URLs
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)/?$ $1.php [NC,L]
</IfModule>
